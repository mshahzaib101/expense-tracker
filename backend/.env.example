# Database (Docker PostgreSQL — run `docker compose up -d` from project root)
DATABASE_URL="postgresql://expense_user:expense_pass@localhost:5432/expense_tracker"

# JWT
JWT_SECRET="super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRATION="7d"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Server Port
PORT=3001
